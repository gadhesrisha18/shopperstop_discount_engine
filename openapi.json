{
  "openapi": "3.1.0",
  "info": {
    "title": "ShopperStop Promotional Pricing Engine",
    "description": "Configurable, API-driven discount engine for tiered, stacked and time-based promotions.",
    "version": "1.0.0"
  },
  "paths": {
    "/api/v1/bills/calculate": {
      "post": {
        "tags": [
          "Bills"
        ],
        "summary": "Calculate Bill",
        "description": "Calculate the final bill for a cart, applying the customer's tier slab\ndiscount plus any active, applicable promotions (stacked per priority\nand stacking rules, capped at the configured max discount rate).\n\n`preview: true` runs the exact same logic without any side effects\n(nothing is written to the DB either way \u2014 this endpoint is always\nidempotent/side-effect-free; `preview` exists to make that contract\nexplicit to callers such as the Marketing Manager's what-if tooling).",
        "operationId": "calculate_bill_api_v1_bills_calculate_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BillCalculateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BillCalculateResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },

  "components": {
    "schemas": {
      "BillCalculateRequest": {
        "properties": {
          "cart_items": {
            "items": {
              "$ref": "#/components/schemas/CartItemIn"
            },
            "type": "array",
            "minItems": 1,
            "title": "Cart Items"
          },
          "customer_tier": {
            "type": "string",
            "title": "Customer Tier",
            "description": "e.g. REGULAR, PREMIUM",
            "default": "REGULAR"
          },
          "store_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Store Id"
          },
          "coupon_codes": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Coupon Codes"
          },
          "now": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Now",
            "description": "Override evaluation time, mainly for testing time-based promos"
          },
          "preview": {
            "type": "boolean",
            "title": "Preview",
            "description": "If true, calculation is not persisted/counted anywhere (idempotent preview)",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "cart_items"
        ],
        "title": "BillCalculateRequest"
      },
      "BillCalculateResponse": {
        "properties": {
          "cart_subtotal": {
            "type": "number",
            "title": "Cart Subtotal"
          },
          "total_discount": {
            "type": "number",
            "title": "Total Discount"
          },
          "final_amount": {
            "type": "number",
            "title": "Final Amount"
          },
          "customer_tier": {
            "type": "string",
            "title": "Customer Tier"
          },
          "discounts_breakdown": {
            "items": {
              "$ref": "#/components/schemas/DiscountBreakdownOut"
            },
            "type": "array",
            "title": "Discounts Breakdown"
          },
          "capped": {
            "type": "boolean",
            "title": "Capped",
            "default": false
          },
          "cap_rate": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Cap Rate"
          },
          "correlation_id": {
            "type": "string",
            "title": "Correlation Id"
          }
        },
        "type": "object",
        "required": [
          "cart_subtotal",
          "total_discount",
          "final_amount",
          "customer_tier",
          "discounts_breakdown",
          "correlation_id"
        ],
        "title": "BillCalculateResponse"
      },
      "CartItemIn": {
        "properties": {
          "sku": {
            "type": "string",
            "title": "Sku"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "category": {
            "type": "string",
            "title": "Category",
            "default": "GENERAL"
          },
          "unit_price": {
            "type": "number",
            "exclusiveMinimum": 0.0,
            "title": "Unit Price",
            "description": "Must be a positive number"
          },
          "quantity": {
            "type": "integer",
            "exclusiveMinimum": 0.0,
            "title": "Quantity",
            "description": "Must be at least 1"
          }
        },
        "type": "object",
        "required": [
          "sku",
          "name",
          "unit_price",
          "quantity"
        ],
        "title": "CartItemIn"
      },
      "CustomerTierCreateRequest": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "label": {
            "type": "string",
            "title": "Label"
          },
          "slabs": {
            "items": {
              "$ref": "#/components/schemas/SlabIn"
            },
            "type": "array",
            "title": "Slabs"
          }
        },
        "type": "object",
        "required": [
          "id",
          "label",
          "slabs"
        ],
        "title": "CustomerTierCreateRequest"
      },
      "CustomerTierOut": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "label": {
            "type": "string",
            "title": "Label"
          },
          "slabs": {
            "items": {
              "type": "object"
            },
            "type": "array",
            "title": "Slabs"
          }
        },
        "type": "object",
        "required": [
          "id",
          "label",
          "slabs"
        ],
        "title": "CustomerTierOut"
      },
      "CustomerTierUpdateRequest": {
        "properties": {

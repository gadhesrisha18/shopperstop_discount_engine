    "/api/v1/promotions/simulate": {
      "post": {
        "tags": [
          "Promotions"
        ],
        "summary": "Simulate Promotion",
        "description": "Lets Marketing preview the effect of a promotion config BEFORE saving/activating it.\nCombines the draft promotion with the store's currently active promotions\nso marketing can see the *real* stacked outcome, not just the new promo in isolation.",
        "operationId": "simulate_promotion_api_v1_promotions_simulate_post",
        "requestBody": {

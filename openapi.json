            "title": "Label"
          },
          "slabs": {
            "anyOf": [
              {
                "items": {
                  "$ref": "#/components/schemas/SlabIn"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Slabs"
          }
        },
        "type": "object",
        "title": "CustomerTierUpdateRequest"
      },
      "DiscountBreakdownOut": {
        "properties": {
          "discount_id": {
            "type": "string",
            "title": "Discount Id"
          },
          "discount_name": {
            "type": "string",
            "title": "Discount Name"
          },
          "discount_type": {
            "type": "string",
            "title": "Discount Type"
          },
          "amount_off": {
            "type": "number",
            "title": "Amount Off"
          },
          "priority": {
            "type": "integer",
            "title": "Priority"
          },
          "applied": {
            "type": "boolean",
            "title": "Applied"
          },
          "detail": {
            "type": "string",
            "title": "Detail",
            "default": ""
          },
          "skipped_reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Skipped Reason"
          }
        },
        "type": "object",
        "required": [
          "discount_id",
          "discount_name",
          "discount_type",
          "amount_off",
          "priority",
          "applied"
        ],
        "title": "DiscountBreakdownOut"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "version": {
            "type": "string",
            "title": "Version"
          },
          "db": {
            "type": "string",
            "title": "Db"
          }
        },
        "type": "object",
        "required": [
          "status",
          "version",
          "db"
        ],
        "title": "HealthResponse"
      },
      "PromotionCreateRequest": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "discount_type": {
            "type": "string",
            "title": "Discount Type",
            "description": "SLAB | FLAT | PERCENTAGE | CATEGORY | BUY_X_GET_Y | TIME_BASED"
          },
          "description": {
            "type": "string",
            "title": "Description",
            "default": ""
          },
          "params": {
            "type": "object",
            "title": "Params",
            "description": "Type-specific parameters, see API docs for schema per type"
          },
          "priority": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Priority",
            "default": 100
          },
          "stackable": {
            "type": "boolean",
            "title": "Stackable",
            "default": true
          },
          "store_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Store Ids"
          },
          "customer_tiers": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Customer Tiers"
          },
          "starts_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Starts At"
          },
          "ends_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ends At"
          },
          "is_active": {
            "type": "boolean",
            "title": "Is Active",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "name",
          "discount_type",
          "params"
        ],
        "title": "PromotionCreateRequest"
      },
      "PromotionListResponse": {
